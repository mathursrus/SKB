# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=

# Server
PORT=
NODE_ENV=development

# GitHub (for issue filing endpoint)
GITHUB_TOKEN=
GITHUB_OWNER=mathursrus
GITHUB_REPO=SKB

# Host-stand auth
SKB_HOST_PIN=
SKB_COOKIE_SECRET=

# Public URL (used for canonical links, OG tags, and JSON-LD in queue page)
# Set to your production domain in deployed environments.
# For local dev: http://localhost:3000
PUBLIC_URL=

# Timezone (service-day partitioning in PT)
TZ=America/Los_Angeles

# FRAIM branch override (optional; otherwise detected from git)
FRAIM_BRANCH=

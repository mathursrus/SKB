# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=

# Server
PORT=
NODE_ENV=development

# GitHub (for issue filing endpoint)
GITHUB_TOKEN=
GITHUB_OWNER=mathursrus
GITHUB_REPO=SKB

# Host-stand auth
SKB_HOST_PIN=
SKB_COOKIE_SECRET=

# SMS (Twilio — future ACS migration in #33)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Public base URL Twilio can reach — used to build the statusCallback URL
# passed to messages.create() so carrier delivery failures (30034 etc.)
# surface via POST /api/sms/status instead of dying silently after create().
# In prod: https://skb-waitlist.azurewebsites.net. Leave blank locally to
# skip statusCallback wiring (sendSms still works without it).
SKB_PUBLIC_BASE_URL=

# Voice IVR (requires SMS vars above + this flag)
TWILIO_VOICE_ENABLED=          # "true" to enable voice routes (default: disabled)

# Timezone (service-day partitioning in PT)
TZ=America/Los_Angeles

# FRAIM branch override (optional; otherwise detected from git)
FRAIM_BRANCH=

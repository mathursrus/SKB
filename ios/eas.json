{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "base": {
      "node": "22.11.0",
      "ios": {
        "resourceClass": "m-medium"
      },
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://skb-waitlist.azurewebsites.net"
      },
      "channel": "base"
    },
    "development": {
      "extends": "base",
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true,
        "resourceClass": "m-medium"
      },
      "channel": "development",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "http://localhost:3000"
      }
    },
    "preview": {
      "extends": "base",
      "distribution": "internal",
      "ios": {
        "simulator": false,
        "resourceClass": "m-medium"
      },
      "channel": "preview",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://skb-waitlist.azurewebsites.net"
      }
    },
    "production": {
      "extends": "base",
      "autoIncrement": true,
      "channel": "production",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://skb-waitlist.azurewebsites.net"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6763905189",
        "appleTeamId": "9TKF9YQDND",
        "ascApiKeyPath": "../../../.appstoreconnect/private_keys/AuthKey_7GTJ43FK2C.p8",
        "ascApiKeyId": "7GTJ43FK2C",
        "ascApiKeyIssuerId": "cfb30bbf-a3c5-47d4-a7f7-3dc6dd8309cc"
      }
    }
  }
}

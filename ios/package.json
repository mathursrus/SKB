{
  "name": "skb-host-stand",
  "version": "0.1.0",
  "private": true,
  "description": "SKB (Shri Krishna Bhavan) host stand iOS app — waitlist management for restaurant staff",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "ios": "expo start --ios",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "test": "jest --watchAll=false",
    "eas:build:dev": "eas build --profile development --platform ios",
    "eas:build:preview": "eas build --profile preview --platform ios",
    "eas:build:prod": "eas build --profile production --platform ios",
    "eas:submit:prod": "eas submit --profile production --platform ios"
  },
  "dependencies": {
    "expo": "~52.0.0",
    "expo-constants": "~17.0.3",
    "expo-device": "~7.0.1",
    "expo-linking": "~7.0.3",
    "expo-notifications": "~0.29.11",
    "expo-router": "~4.0.9",
    "expo-secure-store": "~14.0.0",
    "expo-splash-screen": "~0.29.13",
    "expo-status-bar": "~2.0.0",
    "expo-system-ui": "~4.0.4",
    "expo-updates": "~0.27.5",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.9",
    "react-native-gesture-handler": "~2.20.2",
    "react-native-reanimated": "~3.16.1",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "zustand": "^5.0.2"
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@sentry/.*|native-base|react-native-svg))"
    ]
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/react": "~18.3.12",
    "eslint": "^9.15.0",
    "eslint-config-expo": "~8.0.1",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "jest-expo": "~52.0.2",
    "prettier": "^3.3.3",
    "typescript": "~5.3.3"
  }
}

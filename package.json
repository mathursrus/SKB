{
  "name": "skb",
  "version": "0.1.0",
  "private": true,
  "description": "Shri Krishna Bhavan — restaurant operations & waitlist management",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "start": "tsx src/mcp-server.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "mcp": "tsx src/mcp-server.ts",
    "test": "tsx --test \"tests/unit/**/*.test.ts\"",
    "test:integration": "tsx --test --test-concurrency=1 \"tests/integration/**/*.integration.test.ts\"",
    "test:ui": "tsx --test --test-concurrency=1 \"tests/ui/**/*.ui.test.ts\"",
    "test:e2e": "tsx --test --test-concurrency=1 \"e2e/**/*.e2e.test.ts\"",
    "test:prod": "tsx --test --test-concurrency=1 \"prod-validation/**/*.prod.test.ts\"",
    "test:all": "npm test && npm run test:integration && npm run test:ui && npm run test:e2e",
    "stress": "tsx tests/stress/waitlist-stress.ts",
    "stress:heavy": "STRESS_NUM_DINERS=500 STRESS_DURATION_MS=120000 tsx tests/stress/waitlist-stress.ts"
  },
  "dependencies": {
    "@azure/communication-phone-numbers": "^1.5.0",
    "@azure/communication-sms": "^1.2.0-beta.4",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "argon2": "^0.44.0",
    "express": "^4.21.1",
    "mongodb": "^6.10.0",
    "qrcode": "^1.5.4",
    "tsx": "^4.19.2",
    "twilio": "^5.13.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.9.0",
    "@types/qrcode": "^1.5.6",
    "playwright-core": "^1.59.1",
    "typescript": "^5.6.3"
  }
}
